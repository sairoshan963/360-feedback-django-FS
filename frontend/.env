# Set to "true" to use frontend mock data (no backend needed)
# Set to "false" to use the real API (backend must be running on port 8000)
VITE_USE_MOCK=false

# Backend base URL — leave empty for local dev (Vite proxy handles it automatically)
# Set to full URL only when deploying to a server e.g. https://api.yourdomain.com
VITE_API_BASE_URL=

# Google OAuth — must match GOOGLE_CLIENT_ID in backend/.env
VITE_GOOGLE_CLIENT_ID=581506113726-h32th7jgkc9s6b1l2e5t8mb39vd0o4cn.apps.googleusercontent.com
